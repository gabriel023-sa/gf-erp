{
  "name": "gf-erp",
  "version": "1.0.0",
  "description": "GF ERP - sistema web da GF Impressao 3D com API, banco de dados, login e PWA.",
  "main": "server/index.js",
  "scripts": {
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "check": "node --check server/index.js && node --check server/initial-data.js && node --check app.js",
    "prod:check": "npm run check",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "4.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
